.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  flex-shrink: 0;
}

.tag-content {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.tag-content.selected {
  background: linear-gradient(135deg, #fff5f5 0%, #fff0f0 100%);
  border-color: #ff6b6b;
  color: #ff6b6b;
}

.dish-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.dish-card {
  position: relative;
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
}

.dish-card:active {
  background: #f0f0f0;
}

.dish-card.selected {
  border-color: #ff6b6b;
  background: #fff8f8;
}

.dish-image {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.dish-emoji {
  font-size: 40rpx;
}

.dish-name {
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.dish-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.dish-check.checked {
  background: #ff6b6b;
  border-color: #ff6b6b;
  color: #fff;
}